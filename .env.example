APP_PASSCODE=change-me
APP_SECRET=replace-with-a-long-random-secret

# Required for the deployed Vercel version to persist data.
# Create a fine-grained GitHub token with Contents read/write access to this repo.
GITHUB_TOKEN=github_pat_xxx
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
GITHUB_DATA_PATH=remote-data/notes.enc.json
GITHUB_KB_PREFIX=kb/智慧笔记摘要本

# Optional only for temporary demos. Keep false/empty for long-term production.
ALLOW_TEMP_STORE=false
